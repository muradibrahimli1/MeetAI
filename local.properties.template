# Copy this file to `local.properties` and fill in your values.
# `local.properties` is git-ignored — never commit your real keys.

# Android SDK location (Android Studio normally writes this automatically)
sdk.dir=/Users/<you>/Library/Android/sdk

# --- API keys (baked into BuildConfig at build time) ---
# AssemblyAI: https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=your_assemblyai_key

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key

# Supabase (email/password auth + cloud sync). From your Supabase project:
# Settings > API > Project URL and the "anon public" key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
